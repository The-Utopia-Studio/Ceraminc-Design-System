{
  "defaultTheme": "utopia-default",
  "intent": "Themes are token-contract and visual-policy implementations. Utopia Default is the first locked theme, not the entire design system.",
  "coreBoundary": {
    "owns": [
      "semantic token contract",
      "component APIs",
      "accessibility",
      "Arabic-friendly baseline",
      "theme extension mechanism"
    ],
    "doesNotOwn": [
      "brand palette",
      "brand typography",
      "brand icon policy",
      "brand voice",
      "brand-specific layout philosophy"
    ]
  },
  "requiredSemanticRoles": [
    "--background",
    "--foreground",
    "--card",
    "--card-foreground",
    "--primary",
    "--primary-foreground",
    "--secondary",
    "--secondary-foreground",
